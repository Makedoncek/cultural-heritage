# ===========================================
# CultureMap Ukraine — Environment Variables
# ===========================================
# Copy this file to backend/.env and fill in values.
# For Docker production, these are loaded by docker-compose.prod.yml.

# --- Django ---
SECRET_KEY=change-me-to-a-random-string
DEBUG=False
ALLOWED_HOSTS=your-domain.com,your-server-ip

# --- Database ---
DB_NAME=culturemap
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# --- CORS / CSRF ---
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# --- Email (Gmail SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=CultureMap <your-gmail@gmail.com>

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Frontend URL (used in email links) ---
FRONTEND_URL=https://your-domain.com

# --- Frontend Build (Vite) ---
VITE_API_URL=/api
