# ===========================================
# CultureMap Ukraine — Environment Variables
# ===========================================
# Copy this file to backend/.env and fill in values.
# For Docker production, these are loaded by docker-compose.prod.yml.

# --- Django ---
SECRET_KEY=change-me-to-a-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
DB_NAME=culturemap
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# Alternative: single DATABASE_URL (used by Railway)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# --- CORS / CSRF ---
# Comma-separated origins allowed to make API requests
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Comma-separated origins trusted for CSRF (include https:// in production)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Frontend (Vite) ---
# Used at build time by the frontend container
VITE_API_URL=http://localhost:8000/api
